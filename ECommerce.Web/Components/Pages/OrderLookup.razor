@page "/orders/lookup"
@rendermode InteractiveServer
@inject NavigationManager Nav

<h3 class="mb-4"><i class="bi bi-search me-2"></i>Find Order</h3>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Order ID</label>
            <input class="form-control" @bind="_orderId" placeholder="Enter order GUID" />
        </div>
        <button class="btn btn-primary" @onclick="Search" disabled="@string.IsNullOrWhiteSpace(_orderId)">
            <i class="bi bi-search me-1"></i>Search
        </button>
    </div>
</div>

@code {
    private string _orderId = "";

    private void Search()
    {
        if (Guid.TryParse(_orderId, out var id))
        {
            Nav.NavigateTo($"/orders/{id}");
        }
    }
}
