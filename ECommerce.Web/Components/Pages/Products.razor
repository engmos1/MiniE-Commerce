@page "/products"
@rendermode InteractiveServer
@inject ProductApiClient ProductApi

<h3 class="mb-4"><i class="bi bi-box-seam me-2"></i>Products</h3>

@if (_loading)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border text-primary me-2" role="status"></div>
        <span>Loading products...</span>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_result is null || _result.Items.Count == 0)
{
    <div class="alert alert-info">
        No products found. <a href="/products/create">Create one</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Available Qty</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in _result.Items)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td class="text-end">@product.Price.ToString("C")</td>
                        <td class="text-end">
                            <span class="badge @(product.AvailableQuantity > 0 ? "bg-success" : "bg-danger")">
                                @product.AvailableQuantity
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_result.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(_page <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="PreviousPage">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </li>

                @for (int i = 1; i <= _result.TotalPages; i++)
                {
                    var pageNumber = i;
                    <li class="page-item @(pageNumber == _page ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNumber)">@pageNumber</button>
                    </li>
                }

                <li class="page-item @(_page >= _result.TotalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="NextPage">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
            </ul>
        </nav>
    }

    <p class="text-muted text-center">
        Showing page @_result.Page of @_result.TotalPages (@_result.TotalCount total)
    </p>
}

@code {
    private PaginatedResult<ProductDto>? _result;
    private bool _loading = true;
    private string? _error;
    private int _page = 1;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        try
        {
            _loading = true;
            _error = null;
            _result = await ProductApi.GetProductsAsync(_page, PageSize);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load products: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task GoToPage(int page) { _page = page; await LoadProducts(); }
    private async Task PreviousPage() { if (_page > 1) { _page--; await LoadProducts(); } }
    private async Task NextPage() { if (_result is not null && _page < _result.TotalPages) { _page++; await LoadProducts(); } }
}
